public/temp.wav
public/**/*.wav

# -------------------------------------------------------
# public/ 素材ファイル（Push不要 / clone時はフォルダ構造のみ再現）
# -------------------------------------------------------

# 動画素材 (public/videos/) - .gitkeep のみ追跡
public/videos/*
!public/videos/.gitkeep

# 音声ファイル (public/audio/) - .gitkeep と silence.mp3 のみ追跡
public/audio/*
!public/audio/.gitkeep
!public/audio/silence.mp3
public/audio/temp_story/*
!public/audio/temp_story/.gitkeep

# 画像ファイル (public/images/) - .gitkeep のみ追跡
public/images/*
!public/images/.gitkeep

